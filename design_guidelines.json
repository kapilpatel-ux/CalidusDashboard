  "universal_guidelines": [
    "You tend to converge toward generic outputs. Avoid this.",
    "Dark colors look good when used independently without gradients. DO NOT use dark colors as gradients.",
    "Don't make generic centered layouts. Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "You MUST NOT apply universal transition (e.g., transition: all).",
    "You MUST NOT center align the app container.",
    "Always use modern button styles (sharp, uppercase for this tactical theme).",
    "Every interaction needs micro-animations - hover states, transitions.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures/noise overlays separate good from extraordinary.",
    "Missing categories (especially sponsor logos) = main agent will use placeholder text which is FORBIDDEN.",
    "Prioritize using pre-existing components from src/components/ui.",
    "Components MUST use named exports.",
    "Pages MUST use default exports.",
    "Use 'sonner' for toasts.",
    "All interactive elements MUST include data-testid attribute."
  ],
  "instructions_to_main_agent": [
    "1. SETUP: Install 'lucide-react', 'recharts', 'framer-motion', 'clsx', 'tailwind-merge' if not present.",
    "2. THEME: Apply the dark theme classes to the root layout immediately.",
    "3. FONTS: Add 'Barlow Condensed' and 'JetBrains Mono' via Google Fonts link in index.html.",
    "4. LAYOUT: Create a 'Shell' component that includes the Sidebar and Topbar (Role Selector).",
    "5. ROLE SELECTOR: This is the critical feature. Make it prominent in the Topbar (Admin / Supplier / Buyer).",
    "6. DASHBOARDS: Create three distinct dashboard views based on the role selected.",
    "7. DATA: Create a 'mockData.js' file with realistic defense industry data (Orion Defense, Falcon Aerospace, etc.).",
    "8. CHARTS: Use Recharts with the custom colors defined in the palette. Ensure tooltips are styled (dark bg, border).",
    "9. TABLES: Use Shadcn Table component. Add status badges (Approved=Green, Pending=Amber, Rejected=Red).",
    "10. NAVIGATION: Sidebar links must change based on the selected role."
  ]
}
