{
  "theme": "dark",
  "design_philosophy": {
    "name": "Tactical Command OS",
    "archetype": "The Performance Pro (Defense Variant)",
    "core_principles": [
      "Information Density over Decoration",
      "Optical Precision (1px borders, crisp edges)",
      "Situational Awareness (High contrast alerts)",
      "HUD Aesthetics (Monospace data, corner brackets)"
    ],
    "vibe": "Elite, Secure, Mission-Critical, Enterprise-Grade"
  },
  "typography": {
    "primary_font": "Inter",
    "heading_font": "Barlow Condensed",
    "mono_font": "JetBrains Mono",
    "scale": {
      "h1": "text-4xl font-bold tracking-tight uppercase",
      "h2": "text-2xl font-semibold tracking-tight uppercase",
      "h3": "text-xl font-medium tracking-wide",
      "body": "text-sm text-muted-foreground",
      "data": "font-mono text-xs tracking-wider",
      "label": "text-[10px] uppercase tracking-[0.15em] font-semibold text-muted-foreground/70"
    }
  },
  "colors": {
    "palette": {
      "background": "#09090b",
      "foreground": "#f4f4f5",
      "card": "#18181b",
      "card_foreground": "#fafafa",
      "popover": "#18181b",
      "popover_foreground": "#fafafa",
      "primary": "#3b82f6",
      "primary_foreground": "#ffffff",
      "secondary": "#27272a",
      "secondary_foreground": "#fafafa",
      "muted": "#27272a",
      "muted_foreground": "#a1a1aa",
      "accent": "#27272a",
      "accent_foreground": "#fafafa",
      "destructive": "#ef4444",
      "destructive_foreground": "#fafafa",
      "border": "#27272a",
      "input": "#27272a",
      "ring": "#3b82f6"
    },
    "semantic": {
      "success": "#10b981",
      "warning": "#f59e0b",
      "info": "#0ea5e9",
      "tactical_grid": "rgba(59, 130, 246, 0.1)"
    }
  },
  "visual_enhancers": {
    "borders": {
      "default": "border border-border",
      "tactical": "border border-primary/20",
      "corner_accent": "relative after:absolute after:bottom-0 after:right-0 after:h-2 after:w-2 after:border-b-2 after:border-r-2 after:border-primary after:content-['']"
    },
    "shadows": {
      "card": "shadow-none",
      "glow": "shadow-[0_0_15px_rgba(59,130,246,0.15)]"
    },
    "gradients": {
      "surface": "bg-gradient-to-b from-white/[0.05] to-transparent",
      "active_item": "bg-gradient-to-r from-primary/10 to-transparent border-l-2 border-primary"
    },
    "glassmorphism": {
      "header": "bg-background/80 backdrop-blur-md border-b border-white/5",
      "overlay": "bg-black/60 backdrop-blur-sm"
    }
  },
  "layout_strategy": {
    "container": "max-w-[1600px] mx-auto p-6",
    "grid_system": "grid grid-cols-1 md:grid-cols-12 gap-6",
    "dashboard_grid": "grid grid-cols-1 md:grid-cols-4 gap-4",
    "spacing": {
      "section_gap": "gap-8",
      "widget_padding": "p-5"
    }
  },
  "components": {
    "buttons": {
      "primary": "rounded-sm font-semibold uppercase tracking-wider text-xs h-9 px-4 shadow-[0_0_10px_rgba(59,130,246,0.2)] hover:shadow-[0_0_15px_rgba(59,130,246,0.4)] transition-all",
      "outline": "rounded-sm border-white/10 hover:bg-white/5 hover:text-white uppercase tracking-wider text-xs",
      "ghost": "hover:bg-white/5 uppercase tracking-wider text-xs"
    },
    "cards": {
      "base": "rounded-sm border bg-card/50 backdrop-blur-sm",
      "interactive": "hover:border-primary/50 transition-colors cursor-pointer group"
    },
    "inputs": {
      "base": "bg-black/20 border-white/10 focus-visible:ring-primary/50 focus-visible:border-primary/50 rounded-sm"
    },
    "charts": {
      "style": "tactical",
      "grid_color": "#333",
      "tooltip_bg": "#18181b",
      "tooltip_border": "#333"
    },
    "tables": {
      "header": "text-[10px] uppercase tracking-wider text-muted-foreground bg-white/5",
      "row": "border-b border-white/5 hover:bg-white/[0.02] transition-colors",
      "cell": "py-3 text-sm font-medium"
    }
  },
